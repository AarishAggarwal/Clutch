# Copy to `.env.local`. Next.js loads this over `.env`.

# =============================================================================
# PostgreSQL for Prisma (Vercel Postgres, Neon, Railway, etc. — not Supabase)
# =============================================================================
#
# Vercel (recommended for this repo):
# 1. Deploy once or create a project.
# 2. Open the project → Storage → Create Database → Postgres (Vercel Postgres / Neon).
# 3. In the database panel, copy the connection string Vercel labels for Prisma
#    (often `POSTGRES_PRISMA_URL` or similar — pooled is fine for this app + migrate).
#
# 4. In Vercel → Project → Settings → Environment Variables, add DATABASE_URL
#    (and any OPENAI_API_KEY etc.).
#
# 5. Locally: put the same DATABASE_URL in `.env.local` and/or `.env` so Prisma CLI works.
#
# If `prisma migrate deploy` ever fails with a pooler-only error (rare on Neon), run it
# once using the host’s non-pooling URL as DATABASE_URL in the shell only.

DATABASE_URL=""

# Optional: limit College Scorecard API import (default = full catalog). Example: MAX_SCHOOLS=500
# MAX_SCHOOLS=""

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_EVAL_MODEL="gpt-4o-mini"
ANTHROPIC_EVAL_MODEL="claude-3-5-sonnet-latest"
ANTHROPIC_BASE_URL=""

# https://api.data.gov/signup/ — free key. Required to load the full university catalog:
#   npm run db:sync-universities-api
# (Run locally with DATABASE_URL pointed at Neon; serverless requests cannot finish a full sync.)
COLLEGE_SCORECARD_API_KEY=""

NEXT_PUBLIC_APPS_OPEN_AT="2026-08-01T00:00:00-04:00"

# =============================================================================
# Auth (NextAuth + Resend OTP for email sign-up)
# =============================================================================
# Generate secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=""
# Local: http://localhost:3000  |  Production: https://www.clucht-edu.com
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — https://resend.com/api-keys
RESEND_API_KEY=""
# Use a verified sender after domain setup, e.g.:
# AUTH_EMAIL_FROM="Clutch Edu <noreply@updates.clucht-edu.com>"
# Until then Resend allows: onboarding@resend.dev
AUTH_EMAIL_FROM="Clutch Edu <onboarding@resend.dev>"
