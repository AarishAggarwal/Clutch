# Copy to `.env.local`. Next.js loads this over `.env`.

# =============================================================================
# PostgreSQL for Prisma (Vercel Postgres, Neon, Railway, etc. — not Supabase)
# =============================================================================
#
# Vercel (recommended for this repo):
# 1. Deploy once or create a project.
# 2. Open the project → Storage → Create Database → Postgres (Vercel Postgres / Neon).
# 3. In the database panel, copy the connection string Vercel labels for Prisma
#    (often `POSTGRES_PRISMA_URL` or similar — pooled is fine for this app + migrate).
#
# 4. In Vercel → Project → Settings → Environment Variables, add DATABASE_URL
#    (and any OPENAI_API_KEY etc.).
#
# 5. Locally: set a nonempty DATABASE_URL in `.env.local` (below). Prisma CLI does not load
#    `.env.local` by default — run migrations with:
#      npm run db:migrate
#    (or paste the same URL into `.env` if you prefer raw `npx prisma migrate deploy`).
#    Never set DATABASE_URL="" in `.env` — Prisma will fail with P1012.
#
# If migrate ever fails with a pooler-only error (rare on Neon), run it once using the host’s
# non-pooling URL as DATABASE_URL in the shell only.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional: limit College Scorecard API import (default = full catalog). Example: MAX_SCHOOLS=500
# MAX_SCHOOLS=""

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Optional overrides (default: OPENAI_EVAL_MODEL or gpt-4o-mini / gpt-4o)
# OPENAI_PROJECT_IDEATOR_MODEL="gpt-4o"
# OPENAI_PROJECT_MODEL="gpt-4o-mini"
OPENAI_EVAL_MODEL="gpt-4o-mini"
ANTHROPIC_EVAL_MODEL="claude-3-5-sonnet-latest"
ANTHROPIC_BASE_URL=""

# https://api.data.gov/signup/ — free key. Required to load the full university catalog:
#   npm run db:sync-universities-api
# (Run locally with DATABASE_URL pointed at Neon; serverless requests cannot finish a full sync.)
COLLEGE_SCORECARD_API_KEY=""

NEXT_PUBLIC_APPS_OPEN_AT="2026-08-01T00:00:00-04:00"

# =============================================================================
# Auth (NextAuth + Resend OTP for email sign-up)
# =============================================================================
# Generate secret: `openssl rand -base64 32`
NEXTAUTH_SECRET=""
# Local: http://localhost:3000  |  Production: https://www.clucht-edu.com
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend — https://resend.com/api-keys
# Required on Vercel (Production + Preview if you test sign-up there): set RESEND_API_KEY.
#
# IMPORTANT: onboarding@resend.dev only works for limited testing (often only your Resend
# account email). For sign-ups from any real address, verify your domain in Resend and set:
#   AUTH_EMAIL_FROM="ClutchAI <noreply@yourdomain.com>"
RESEND_API_KEY=""
# Production example after domain verification:
# AUTH_EMAIL_FROM="ClutchAI <noreply@updates.clucht-edu.com>"
# Local/testing only (not for arbitrary recipient emails):
AUTH_EMAIL_FROM="ClutchAI <onboarding@resend.dev>"

# =============================================================================
# Razorpay (Marketplace — admitted application purchases)
# =============================================================================
# Test keys from Razorpay Dashboard → API Keys. Never commit real production secrets.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
