# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env & secrets (never commit real keys)
.env
.env*.local

# local sqlite (use Postgres in production)
prisma/*.db
prisma/*.db-journal

# large local datasets — keep out of git (breaks Vercel / huge clones)
College_Scorecard_Raw_Data_03232026/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local
